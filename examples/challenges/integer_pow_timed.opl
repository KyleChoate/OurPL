
fun integer_power(base, exponent)
{
    if (exponent == 0)
    {
        return 1;
    }

    if (exponent > 0)
    {
        return base * integer_power(base, exponent - 1);
    }

    else
    {
        return (1 / base) * integer_power(base, exponent + 1);
    }
}


var time = clock();
for(var i = 1 ; i < 40000 ; i = i + 1)
    integer_power(i, 100);

var tmp = clock();

print (tmp - time);
